# =============================================================================
# musteri.enndip.com — Ortam Değişkenleri
# Vercel → Project Settings → Environment Variables'a girin.
# Yerelde bu dosyayı .env.local olarak kopyalayın.
# =============================================================================

# --- Supabase (tarayıcı auth / PKCE için public) ---
NEXT_PUBLIC_SUPABASE_URL=https://pbdzhcepbjcbuajqkewe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # Supabase anon key

# --- NestJS Core API (server-only, /api/v1 dahil) ---
# Token tarayıcıya inmez; çağrılar yalnızca Next.js sunucusundan yapılır.
API_BASE_URL=https://enndipbackend-production.up.railway.app/api/v1

# --- Vehicle Imagery proxy mutlak URL tabanı (opsiyonel) ---
# Backend API_PUBLIC_BASE_URL ile aynı; boşsa API_BASE_URL host'u kullanılır.
API_PUBLIC_BASE_URL=https://enndipbackend-production.up.railway.app/api/v1

# --- Site (OAuth redirect + metadata) ---
NEXT_PUBLIC_SITE_URL=https://musteri.enndip.com
